rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Resume Uploads
    match /resumes/{userId}/{allPaths=**} {
      // Allow user to read/write their own resumes
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Basic validation for content type (optional but recommended)
      // allow write: if request.auth.uid == userId && request.resource.contentType.matches('application/pdf');
    }
    
    // Public Assets (Read only for all)
    match /public/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
