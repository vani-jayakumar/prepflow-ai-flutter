rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDataOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    // User Profile Rules
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      
      // Allow specific subcollections if any, inheriting permissions
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // Mock Interview Session Rules
    match /sessions/{sessionId} {
      // Permission to create if setting own userId
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      // Permission to read/update if owner
      allow read, update, delete: if isDataOwner();
    }

    // Interview Tracker Rules
    match /interview_logs/{logId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isDataOwner();
    }

    // Universal Question Bank (Read only for users)
    match /questions/{questionId} {
      allow read: if isAuthenticated();
      allow write: if false; // Admin only via console
    }
  }
}
